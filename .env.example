# Application
APP_NAME=Meta Ads Agent
DEBUG=true
DEMO_MODE=true

# Database (SQLite - no setup needed)
DATABASE_URL=sqlite:///./meta_ads_agent.db

# Ollama Cloud AI
OLLAMA_API_URL=https://api.ollama.cloud/v1
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=gpt-oss:120b-cloud
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7
AI_TIMEOUT=120

# Slack Integration (Optional - leave blank to disable)
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# Agent Configuration
AGENT_CYCLE_INTERVAL=14400
AUTO_APPROVAL_BUDGET_THRESHOLD=5000
AUTO_PAUSE_CPA_MULTIPLIER=3.0
AUTO_SCALE_ROAS_THRESHOLD=3.5

# Demo Data Configuration
DEMO_CAMPAIGN_COUNT=8
DEMO_SIMULATE_VARIANCE=true

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080
